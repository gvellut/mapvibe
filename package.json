{
    "name": "mapvibe",
    "version": "1.0.0",
    "description": "A static map interface component for embedding in blog posts or websites, as a Google My Maps replacement",
    "type": "module",
    "main": "./dist/mapvibe.cjs",
    "module": "./dist/mapvibe.mjs",
    "types": "./dist/lib.d.ts",
    "exports": {
        ".": {
            "types": "./dist/lib.d.ts",
            "import": "./dist/mapvibe.mjs",
            "require": "./dist/mapvibe.cjs"
        },
        "./style.css": "./dist/mapvibe.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:lib": "vite build --config vite.config.lib.ts && tsc -p tsconfig.lib.json",
        "preview": "vite preview",
        "copy-dist": "dotenv -e .env -- sh -c 'rsync -av --delete dist/ $BLOG_STATIC_FOLDER'",
        "prepublishOnly": "npm run build:lib"
    },
    "keywords": [
        "map",
        "maplibre",
        "react",
        "typescript",
        "geospatial",
        "interactive-map",
        "embed"
    ],
    "author": "",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gvellut/mapvibe.git"
    },
    "peerDependencies": {
        "maplibre-gl": "^5.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "dotenv-cli": "^11.0.0",
        "maplibre-gl": "^5.19.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sass": "^1.97.3",
        "typescript": "~5.9.3",
        "vite": "^7.3.1"
    }
}